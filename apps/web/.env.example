# ============================================================
# MCP Server Credentials — Generated by Antigravity Studio
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# GitHub MCP (TIER 2 — Optional)
# GitHub Personal Access Token with repo scope
# Get it at: https://github.com/settings/tokens/new?scopes=repo,read:org
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Chromatic Visual Testing MCP (TIER 3 — Required)
# Chromatic project token for visual testing
# Get it at: https://www.chromatic.com/docs/cli#project-tokens
CHROMATIC_PROJECT_TOKEN=chpt_xxxxxxxxxxxxxxxxxxxx

