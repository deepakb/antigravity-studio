    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.18.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.2",
