{
  "name": "nexus-studio-monorepo",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "standardize-skills": "node scripts/standardize-skills.mjs",
    "standardize-skills:dry": "node scripts/standardize-skills.mjs --dry-run",
    "add-frontmatter": "node scripts/add-agent-frontmatter.mjs",
    "add-frontmatter:dry": "node scripts/add-agent-frontmatter.mjs --dry-run",
    "token-budgets": "node scripts/compute-token-budgets.mjs",
    "token-budgets:dry": "node scripts/compute-token-budgets.mjs --dry-run"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}
